# Supabase — Mini Brief backend
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Publishable anon key — safe in the browser (used by the /admin dashboard).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only; only needed by the newsletter/email lib.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (optional at runtime — confirmation email skipped if missing)
RESEND_API_KEY=
# Must be on a verified Resend domain (e.g. "Mini Brief <hello@minibrief.app>")
RESEND_FROM_EMAIL=
